<% content_for :title, "Roles" %>

<div class="page-header">
  <div>
    <h1>Roles</h1>
    <p class="page-subtitle">Define access roles for the CRM.</p>
  </div>
  <div>
    <%= link_to "New Role", new_role_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="card">
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th class="table-actions"></th>
      </tr>
    </thead>
    <tbody>
      <% @roles.each do |role| %>
        <tr>
          <td><strong><%= role.name %></strong></td>
          <td class="table-actions">
            <%= link_to "Edit", edit_role_path(role), class: "btn btn-ghost" %>
            <%= link_to "Delete", role_path(role), class: "btn btn-ghost btn-danger", data: { turbo_method: :delete, turbo_confirm: "Remove this role?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
