<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dealership" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app-shell">
      <header class="app-topbar">
        <div class="container topbar-inner">
          <div class="app-brand">
            <span class="brand-mark"></span>
            <span class="brand-name">Dealership Ops</span>
          </div>
          <nav class="app-nav">
            <%= link_to "Dashboard", dashboard_path, class: "nav-link" %>
            <%= link_to "Leads", leads_path, class: "nav-link" %>
            <%= link_to "Gate Entries", gate_entries_path, class: "nav-link" %>
            <%= link_to "Stages", lead_stages_path, class: "nav-link" %>
            <%= link_to "Users", users_path, class: "nav-link" %>
            <%= link_to "Roles", roles_path, class: "nav-link" %>
          </nav>
        </div>
      </header>

      <main class="app-main">
        <div class="container <%= content_for?(:container_class) ? yield(:container_class) : "" %>">
          <% if notice.present? %>
            <div class="flash flash-notice"><%= notice %></div>
          <% end %>
          <% if alert.present? %>
            <div class="flash flash-alert"><%= alert %></div>
          <% end %>
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
